---
const areas = [
  ['Daños y perjuicios', 'Reclamamos la reparación justa frente a accidentes, incumplimientos y otros daños.'],
  ['Derecho laboral', 'Defendemos a trabajadores ante despidos, diferencias salariales y vulneración de derechos.'],
  ['Derecho penal', 'Brindamos una defensa firme y estratégica, con respeto por las garantías del debido proceso.'],
  ['Derecho civil', 'Intervenimos en contratos, sucesiones, conflictos patrimoniales y reclamos entre particulares.'],
  ['Derecho de familia', 'Acompañamos divorcios, alimentos, cuidado personal y otros procesos familiares sensibles.'],
  ['Derecho comercial', 'Asesoramos a empresas en contratos, cobros, concursos y litigios comerciales.'],
]
---
<section id="servicios" class="areas">
  <div class="container">
    <header class="section-head">
      <div>
        <p class="eyebrow">Áreas de práctica</p>
        <h2 class="section-title">En qué nos especializamos</h2>
      </div>
      <p class="section-copy">Abordamos cada asunto con análisis riguroso, comunicación directa y una estrategia diseñada para cada cliente.</p>
    </header>
    <div class="areas-grid">
      {areas.map(([title, text], i) => (
        <article class="area-card">
          <span class="area-number">0{i + 1}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v18M5 7h14M7 7l-4 7h8L7 7Zm10 0-4 7h8l-4-7ZM8 21h8"/></svg>
          <h3>{title}</h3>
          <p>{text}</p>
          <a href="#contacto" aria-label={`Consultar por ${title}`}>Consultar <span aria-hidden="true">↗</span></a>
        </article>
      ))}
    </div>
  </div>
</section>
<style>
  .areas{padding:clamp(6.4rem,10vw,9.2rem) 0;background:#f6f4ef}
  .section-head{display:grid;grid-template-columns:1.1fr .7fr;align-items:end;gap:3.5rem;margin-bottom:3.9rem}
  .section-head .section-copy{margin:0}
  .areas-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.18rem;align-items:stretch}
  .area-card{position:relative;min-height:318px;padding:2.25rem 2.1rem 2rem;background:linear-gradient(180deg,#fff,#fdfcf9);border:1px solid #e4e0d8;border-radius:14px;box-shadow:0 4px 14px rgba(26,46,42,.025);transition:transform .28s ease,border-color .28s ease,box-shadow .28s ease,background .28s ease}
  .area-card:before{content:"";position:absolute;left:2.1rem;top:0;width:50px;height:3px;border-radius:0 0 4px 4px;background:#c4a06f}
  .area-card:after{content:"";position:absolute;inset:12px;border:1px solid transparent;border-radius:10px;pointer-events:none;transition:border-color .28s ease}
  .area-card:hover{z-index:1;transform:translateY(-4px);border-color:#d7c8b3;box-shadow:0 12px 32px rgba(26,46,42,.055);background:#fff}
  .area-card:hover:after{border-color:#eee5d7}
  .area-number{position:absolute;right:1.55rem;top:1.45rem;color:#9ca19d;font-size:.72rem;font-weight:800;letter-spacing:.14em}
  .area-card svg{width:39px;height:39px;margin:1rem 0 1.9rem;fill:none;stroke:#b58a51;stroke-width:1.12;stroke-linecap:round;stroke-linejoin:round}
  .area-card h3{margin:0;font-size:1.78rem;line-height:1.12}
  .area-card p{min-height:76px;margin:1.05rem 0 1.25rem;color:#636d6a;font-size:.94rem;line-height:1.68}
  .area-card a{display:inline-flex;gap:.5rem;color:#123c3b;font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em}
  @media(max-width:900px){.areas-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:650px){
    .areas{padding-block:5.6rem}
    .section-head{grid-template-columns:1fr;gap:1.4rem;margin-bottom:2.8rem}
    .areas-grid{grid-template-columns:1fr}
    .area-card{min-height:0;padding:2.1rem 1.75rem 1.85rem}
    .area-card p{min-height:0}
  }
</style>
