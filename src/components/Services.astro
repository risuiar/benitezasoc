---
const services = [
  ['Asesoramiento legal integral', 'Evaluación clara del caso y sus alternativas.'],
  ['Representación en juicios', 'Defensa técnica durante todas las instancias.'],
  ['Negociaciones y acuerdos', 'Soluciones eficientes cuando el diálogo es posible.'],
  ['Defensa de derechos', 'Acciones concretas para proteger sus intereses.'],
  ['Documentos legales', 'Redacción y revisión precisa de contratos y escritos.'],
  ['Acompañamiento personalizado', 'Comunicación cercana durante todo el proceso.'],
]
---
<section class="process">
  <div class="container">
    <div class="process-head">
      <p class="eyebrow">Cómo trabajamos</p>
      <h2 class="section-title">Un proceso claro,<br />desde el primer contacto</h2>
    </div>
    <ol class="steps">
      <li><span>01</span><div><h3>Escuchamos tu caso</h3><p>Conocemos tu situación, tus inquietudes y el resultado que necesitás.</p></div></li>
      <li><span>02</span><div><h3>Analizamos la estrategia</h3><p>Evaluamos las alternativas y te explicamos con claridad los próximos pasos.</p></div></li>
      <li><span>03</span><div><h3>Te acompañamos</h3><p>Actuamos con diligencia y mantenemos una comunicación directa durante el proceso.</p></div></li>
    </ol>
  </div>
</section>
<section class="services">
  <div class="container services-grid">
    <div class="services-copy">
      <p class="eyebrow">Servicios principales</p>
      <h2 class="section-title">Respuestas legales para cada etapa</h2>
      <p class="section-copy">Nuestro equipo combina experiencia y especialización para ofrecer una atención integral, clara y orientada a resultados.</p>
    </div>
    <div class="service-list">
      {services.map(([title, text]) => (
        <article><span aria-hidden="true">✓</span><div><h3>{title}</h3><p>{text}</p></div></article>
      ))}
    </div>
  </div>
</section>
<style>
  .process{padding:clamp(6.4rem,10vw,9.2rem) 0;color:#fff;background:linear-gradient(180deg,#123c3b,#0f3433)}
  .process-head{display:flex;align-items:end;justify-content:space-between;gap:3.5rem;margin-bottom:4.15rem}
  .process .section-title{max-width:670px}
  .process .eyebrow{margin-bottom:.45rem}
  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1.35rem;margin:0;padding:0;list-style:none}
  .steps li{position:relative;display:flex;gap:1.25rem;padding:2.05rem 1.75rem;border:1px solid #ffffff24;border-radius:13px;background:#ffffff09;box-shadow:inset 0 1px 0 #ffffff12}
  .steps li:after{content:"";position:absolute;right:-1.35rem;top:50%;width:1.35rem;height:1px;background:#d4aa7266}
  .steps li:last-child:after{display:none}
  .steps>li>span{display:grid;flex:0 0 42px;height:42px;place-items:center;border:1px solid #d4aa727c;border-radius:50%;color:#d8b37d;background:#0b29284a;font:600 1rem "Cormorant Garamond",serif}
  .steps h3{margin:.12rem 0 .72rem;font-size:1.58rem;line-height:1.12}
  .steps p{margin:0;color:#dce4e1;font-size:.96rem;line-height:1.72}
  .services{padding:clamp(6.4rem,10vw,9.2rem) 0;background:#fff}
  .services-grid{display:grid;grid-template-columns:.82fr 1.18fr;align-items:start;gap:clamp(3.8rem,8vw,7rem)}
  .services-copy{position:sticky;top:2rem}
  .services .section-copy{max-width:470px;margin-top:1.75rem}
  .service-list{display:grid;grid-template-columns:repeat(2,1fr);gap:1.05rem}
  .service-list article{display:flex;min-height:132px;gap:1.05rem;padding:1.52rem 1.38rem;border:1px solid #e4e0d8;border-radius:12px;background:#fdfcf9;transition:border-color .25s ease,transform .25s ease,background .25s ease}
  .service-list article:hover{transform:translateY(-3px);border-color:#d8c8b0;background:#fff}
  .service-list>article>span{display:grid;flex:0 0 34px;height:34px;place-items:center;border:1px solid #dfcfb9;border-radius:50%;color:#a97e46;background:#f7f0e6;font-size:.76rem;font-weight:800}
  .service-list h3{margin:0 0 .52rem;font-size:1.34rem;line-height:1.14}
  .service-list p{margin:0;color:#636d6a;font-size:.9rem;line-height:1.62}
  @media(max-width:860px){
    .process-head{display:block;margin-bottom:2.8rem}
    .steps,.services-grid{grid-template-columns:1fr}
    .steps li:after{display:none}
    .services-copy{position:static}
    .service-list{margin-top:.2rem}
  }
  @media(max-width:560px){
    .process,.services{padding-block:5.6rem}
    .steps li{padding:1.65rem 1.35rem}
    .steps h3{font-size:1.42rem}
    .service-list{grid-template-columns:1fr}
    .service-list article{min-height:0}
  }
</style>
