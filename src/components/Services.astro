---
const services=[['Asesoramiento legal integral','Evaluación clara del caso y sus alternativas.'],['Representación en juicios','Defensa técnica durante todas las instancias.'],['Negociaciones y acuerdos','Soluciones eficientes cuando el diálogo es posible.'],['Defensa de derechos','Acciones concretas para proteger sus intereses.'],['Documentos legales','Redacción y revisión precisa de contratos y escritos.'],['Acompañamiento personalizado','Comunicación cercana durante todo el proceso.']]
---
<section class="process"><div class="container"><div class="process-head"><p class="eyebrow">Cómo trabajamos</p><h2 class="section-title">Un proceso claro,<br/>desde el primer contacto</h2></div><ol class="steps"><li><span>01</span><div><h3>Escuchamos tu caso</h3><p>Conocemos tu situación, tus inquietudes y el resultado que necesitás.</p></div></li><li><span>02</span><div><h3>Analizamos la estrategia</h3><p>Evaluamos las alternativas y te explicamos con claridad los próximos pasos.</p></div></li><li><span>03</span><div><h3>Te acompañamos</h3><p>Actuamos con diligencia y mantenemos una comunicación directa durante el proceso.</p></div></li></ol></div></section>
<section class="services"><div class="container services-grid"><div><p class="eyebrow">Servicios principales</p><h2 class="section-title">Respuestas legales para cada etapa</h2><p class="section-copy">Nuestro equipo combina experiencia y especialización para ofrecer una atención integral.</p></div><div class="service-list">{services.map(([title,text])=><article><span aria-hidden="true">✓</span><div><h3>{title}</h3><p>{text}</p></div></article>)}</div></div></section>
<style>
.process{padding:clamp(6rem,10vw,9rem) 0;color:#fff;background:#123c3b}.process-head{display:flex;align-items:end;justify-content:space-between;gap:3.5rem;margin-bottom:4.2rem}.process .section-title{max-width:650px}.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin:0;padding:0;list-style:none}.steps li{position:relative;display:flex;gap:1.4rem;padding:2.1rem 1.9rem;border:1px solid #ffffff1f;border-radius:11px;background:#ffffff08}.steps li:after{content:"";position:absolute;right:-1.25rem;top:50%;width:1.25rem;height:1px;background:#d4aa7266}.steps li:last-child:after{display:none}.steps>li>span{display:grid;flex:0 0 40px;height:40px;place-items:center;border:1px solid #d4aa726e;border-radius:50%;color:#d4aa72;font:600 1rem "Cormorant Garamond",serif}.steps h3{margin:.15rem 0 .7rem;font-size:1.65rem}.steps p{margin:0;color:#cbd5d2;font-size:.9rem;line-height:1.7}.services{padding:clamp(6rem,10vw,9rem) 0;background:#fff}.services-grid{display:grid;grid-template-columns:.78fr 1.22fr;gap:clamp(3.5rem,9vw,8rem)}.services .section-copy{max-width:460px;margin-top:1.8rem}.service-list{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}.service-list article{display:flex;gap:1.1rem;padding:1.55rem 1.4rem;border:1px solid #e6e2da;border-radius:10px;background:#fdfcf9;transition:border-color .25s ease,transform .25s ease,background .25s ease}.service-list article:hover{transform:translateY(-3px);border-color:#d9c9b3;background:#fff}.service-list article:nth-child(even){padding-left:1.4rem;border-left:1px solid #e6e2da}.service-list>article>span{display:grid;flex:0 0 32px;height:32px;place-items:center;border:1px solid #e2d3bc;border-radius:50%;color:#a97e46;background:#f6f0e7;font-size:.72rem}.service-list h3{margin:0 0 .5rem;font-size:1.4rem}.service-list p{margin:0;color:#68716f;font-size:.85rem;line-height:1.55}@media(max-width:800px){.process-head{display:block}.steps,.services-grid{grid-template-columns:1fr}.steps li:after{display:none}.service-list{margin-top:1rem}}@media(max-width:560px){.service-list{grid-template-columns:1fr}.service-list article:nth-child(even){padding-left:1.4rem}}
</style>
