---
<section id="equipo" class="team"><div class="container"><header class="section-head"><div><p class="eyebrow">Profesionales a tu lado</p><h2 class="section-title">Nuestro equipo</h2></div><p class="section-copy">Experiencia, preparación y compromiso puestos al servicio de cada caso.</p></header><div class="team-grid">{team.map(member=><article class="member"><div class="photo"><img src={`/images/team/${member.img}`} alt={`Retrato de ${member.name}`} loading="lazy" width="400" height="600" style={`object-position:${member.position}`}/></div><div class="member-body"><p class="role">{member.role}</p><h3>{member.name}</h3><p class="bio">{member.text}</p><a href={`https://wa.me/549${member.phone}?text=Hola%2C%20quisiera%20realizar%20una%20consulta`} target="_blank" rel="noopener noreferrer" aria-label={`Contactar a ${member.name} por WhatsApp`}>WhatsApp <span aria-hidden="true">↗</span></a></div></article>)}</div></div></section>
<style>
.team{padding:clamp(6rem,10vw,9rem) 0;background:#f6f4ef}.section-head{display:grid;grid-template-columns:1fr .65fr;align-items:end;gap:3.5rem;margin-bottom:3.8rem}.section-head .section-copy{margin:0}.team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.6rem;align-items:stretch}.member{overflow:hidden;background:#fff;border:1px solid #e3dfd6;border-radius:13px;box-shadow:0 3px 14px rgba(26,46,42,.025);transition:transform .3s ease,border-color .3s ease,box-shadow .3s ease}.member:hover{transform:translateY(-5px);border-color:#d7c8b3;box-shadow:var(--soft-shadow)}.photo{height:370px;overflow:hidden;background:#dfe1dc}.photo img{width:100%;height:100%;object-fit:cover;filter:grayscale(.12) saturate(.64) contrast(1.03) sepia(.035);transition:transform .45s ease,filter .45s ease}.member:hover .photo img{transform:scale(1.018);filter:grayscale(.05) saturate(.72) contrast(1.03)}.member-body{padding:1.7rem 1.65rem 1.8rem}.role{margin:0 0 .65rem;color:#aa7d43;font-size:.67rem;font-weight:750;letter-spacing:.14em;text-transform:uppercase}.member h3{margin:0;font-size:1.7rem;line-height:1.08}.bio{min-height:78px;margin:1rem 0 1.15rem;color:#68716f;font-size:.84rem;line-height:1.62}.member a{display:inline-flex;gap:.45rem;padding:.4rem .65rem;border:1px solid #ddcfbb;border-radius:6px;color:#123c3b;font-size:.7rem;font-weight:750;text-transform:uppercase;letter-spacing:.09em;transition:.2s}.member a:hover{background:#f5efe6;border-color:#cdb38f}@media(max-width:900px){.team-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:600px){.section-head{grid-template-columns:1fr;gap:1.2rem;margin-bottom:2.8rem}.team-grid{grid-template-columns:1fr}.photo{height:430px}.bio{min-height:0}}
</style>
