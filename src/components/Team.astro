---
const team = [
  { name: 'Dr. Carlos Adrián Benítez', role: 'Derecho civil y penal', img: 'adrianbenitez.jpg', phone: '3764825360', position: 'center 36%', text: 'Fundador del estudio. Más de 25 años de ejercicio profesional, con trayectoria en litigios, análisis estratégico y defensa comprometida.' },
  { name: 'Dr. Sergio Ariel Wieremiej', role: 'Derecho civil', img: 'sergiowieremiej.jpg', phone: '3764627769', position: 'center 18%', text: 'Profesional con amplia experiencia en conflictos civiles, orientado a soluciones claras, prudentes y sostenidas en el tiempo.' },
  { name: 'Dr. Jorge Damián Villaverde', role: 'Derecho laboral y daños', img: 'jorgevillaverde.jpg', phone: '3764506415', position: 'center 18%', text: 'Integra el estudio desde 2017. Representa a clientes en conflictos laborales y reclamos por daños y perjuicios.' },
  { name: 'Dr. Emmanuel Santiago Rivarola', role: 'Litigios y asesoramiento', img: 'emmanuelraviola.jpg', phone: '3764619703', position: 'center 14%', text: 'Abogado graduado en la UNNE, con práctica orientada a la formación permanente y la atención responsable.' },
  { name: 'Lautaro Benítez', role: 'Asesoramiento y litigios', img: 'lautarobenitez-v2.jpg', phone: '3764238089', position: 'center 18%', text: 'Integra el equipo brindando asesoramiento responsable, atención cercana y acompañamiento profesional en cada caso.' },
  { name: 'Adrián Santiago Villanueva', role: 'Administración y gestión', img: 'adrianvillanueva.jpg', phone: '3765051100', position: 'center 18%', text: 'Desde 2008 coordina la gestión administrativa del estudio, facilitando una atención ordenada, ágil y cercana.' },
]
---
<section id="equipo" class="team">
  <div class="container">
    <header class="section-head">
      <div>
        <p class="eyebrow">Profesionales a tu lado</p>
        <h2 class="section-title">Nuestro equipo</h2>
      </div>
      <p class="section-copy">Experiencia, preparación y compromiso puestos al servicio de cada caso.</p>
    </header>
    <div class="team-grid">
      {team.map((member) => (
        <article class="member">
          <div class="photo">
            <img src={`/images/team/${member.img}`} alt={`Retrato de ${member.name}`} loading="lazy" width="420" height="500" style={`object-position:${member.position}`} />
          </div>
          <div class="member-body">
            <p class="role">{member.role}</p>
            <h3>{member.name}</h3>
            <p class="bio">{member.text}</p>
            <a href={`https://wa.me/549${member.phone}?text=Hola%2C%20quisiera%20realizar%20una%20consulta`} target="_blank" rel="noopener noreferrer" aria-label={`Contactar a ${member.name} por WhatsApp`}>WhatsApp <span aria-hidden="true">↗</span></a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
<style>
  .team{padding:clamp(6.4rem,10vw,9.2rem) 0;background:#f6f4ef}
  .section-head{display:grid;grid-template-columns:1fr .65fr;align-items:end;gap:3.5rem;margin-bottom:3.85rem}
  .section-head .section-copy{margin:0}
  .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.55rem;align-items:stretch}
  .member{overflow:hidden;display:flex;flex-direction:column;background:#fff;border:1px solid #e2ded5;border-radius:15px;box-shadow:0 4px 16px rgba(26,46,42,.028);transition:transform .3s ease,border-color .3s ease,box-shadow .3s ease}
  .member:hover{transform:translateY(-4px);border-color:#d5c6b0;box-shadow:0 14px 34px rgba(26,46,42,.06)}
  .photo{height:355px;overflow:hidden;background:#dfe1dc;border-bottom:1px solid #eee9df}
  .photo img{width:100%;height:100%;object-fit:cover;filter:grayscale(.16) saturate(.58) contrast(1.04) sepia(.055);transition:transform .45s ease,filter .45s ease}
  .member:hover .photo img{transform:scale(1.016);filter:grayscale(.08) saturate(.66) contrast(1.04) sepia(.035)}
  .member-body{display:flex;flex:1;flex-direction:column;padding:1.68rem 1.58rem 1.7rem}
  .role{margin:0 0 .68rem;color:#a7793d;font-size:.72rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;line-height:1.35}
  .member h3{margin:0;font-size:1.72rem;line-height:1.08}
  .bio{flex:1;min-height:86px;margin:1rem 0 1.2rem;color:#636d6a;font-size:.9rem;line-height:1.62}
  .member a{display:inline-flex;align-self:flex-start;align-items:center;gap:.45rem;min-height:38px;padding:.46rem .72rem;border:1px solid #ddcfbb;border-radius:7px;color:#123c3b;font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em;transition:background .2s ease,border-color .2s ease}
  .member a:hover{background:#f5efe6;border-color:#c9ad87}
  @media(max-width:980px){
    .team-grid{grid-template-columns:repeat(2,1fr)}
    .photo{height:370px}
  }
  @media(max-width:650px){
    .team{padding-block:5.6rem}
    .section-head{grid-template-columns:1fr;gap:1.2rem;margin-bottom:2.8rem}
    .team-grid{grid-template-columns:1fr;gap:1.25rem}
    .photo{height:auto;aspect-ratio:4/4.35}
    .member-body{padding:1.55rem 1.42rem 1.55rem}
    .member h3{font-size:1.62rem}
    .bio{min-height:0;font-size:.92rem}
    .member a{width:100%;justify-content:center;min-height:44px}
  }
</style>
