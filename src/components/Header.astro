<script>const b=document.querySelector<HTMLButtonElement>('.menu-toggle');const n=document.querySelector<HTMLElement>('#main-nav');const close=()=>{b?.setAttribute('aria-expanded','false');b?.setAttribute('aria-label','Abrir menú');n?.classList.remove('is-open')};b?.addEventListener('click',()=>{const o=b.getAttribute('aria-expanded')==='true';b.setAttribute('aria-expanded',String(!o));b.setAttribute('aria-label',o?'Abrir menú':'Cerrar menú');n?.classList.toggle('is-open',!o)});n?.querySelectorAll('a').forEach(a=>a.addEventListener('click',close))</script>
